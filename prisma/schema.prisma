// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  password String
  role     String
  state    Int

  articles            Article[]
  favoris             FavoriteArticles[]
  favorisExercices    FavoriteExercises[]
  refreshTokens       RefreshToken[]
  resetTokens         ResetToken[]
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])
}

model Article {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  content     String
  authorId    String   @db.Uuid
  imgUrl      String?
  published   DateTime @default(now())
  status      Int
  readingTime Int

  author  User      @relation(fields: [authorId], references: [id])
  favoris FavoriteArticles[]
}

model FavoriteArticles {
  userId    String @db.Uuid
  articleId String @db.Uuid

  user    User    @relation(fields: [userId], references: [id])
  article Article @relation(fields: [articleId], references: [id])

  @@id([userId, articleId])
}

model BreathingExercise {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  videoUrl    String?
  duration    Int
  benefits    String?
  level       Int
  description String
  steps       Int[]

  favorisExercices FavoriteExercises[]
}

model FavoriteExercises {
  userId     String @db.Uuid
  exerciseId String @db.Uuid

  user     User              @relation(fields: [userId], references: [id])
  exercise BreathingExercise @relation(fields: [exerciseId], references: [id])

  @@id([userId, exerciseId])
}

model ResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])
}